# Copy to application-local.yml in the project root (gitignored) for local development secrets.
# Environment variables override these values when set.

spring:
  datasource:
    password: your-db-password

  security:
    oauth2:
      client:
        registration:
          google:
            client-id: your-google-client-id
            client-secret: your-google-client-secret

app:
  jwt:
    # Base64-encoded 256-bit key for local dev only
    secret: your-jwt-secret
  weather:
    api-key: your-openweather-api-key
    # provider: openweather
